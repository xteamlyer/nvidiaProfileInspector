<Application
    x:Class="nvidiaProfileInspector.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:nvidiaProfileInspector.UI.Converters"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <sys:Boolean x:Key="SearchableComboBoxPopupAllowsTransparency">True</sys:Boolean>
            <primitives:PopupAnimation x:Key="SearchableComboBoxPopupAnimation">Slide</primitives:PopupAnimation>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Styles/Icons.xaml" />
                <ResourceDictionary Source="/UI/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="/UI/Styles/Theme.xaml" />
                <ResourceDictionary Source="/UI/Styles/Snackbar.xaml" />
                <ResourceDictionary Source="/UI/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
